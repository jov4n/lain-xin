---
interface PostItem {
	href: string;
	title: string;
	summary: string;
	date: string;
	dateLabel: string;
}

interface Props {
	posts: PostItem[];
}

const { posts } = Astro.props;
---

<ul class="post-list">
	{
		posts.map((post) => (
			<li>
				<a href={post.href}>
					<time datetime={post.date}>{post.dateLabel}</time>
					<div>
						<h3>{post.title}</h3>
						<p>{post.summary}</p>
					</div>
				</a>
			</li>
		))
	}
</ul>

<style>
	.post-list {
		display: flex;
		flex-direction: column;
	}

	.post-list li {
		border-top: 1px solid var(--hairline);
	}

	.post-list li:last-child {
		border-bottom: 1px solid var(--hairline);
	}

	.post-list a {
		display: grid;
		grid-template-columns: 7rem 1fr;
		gap: var(--space-md);
		padding: var(--space-md) 0;
		color: inherit;
		text-decoration: none;
	}

	.post-list a:hover {
		color: inherit;
	}

	.post-list a:hover h3 {
		color: var(--phosphor);
	}

	time {
		font-size: 0.6875rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--phosphor-dim);
		padding-top: 0.3rem;
	}

	h3 {
		font-size: 1.125rem;
		margin-bottom: 0.35rem;
	}

	.post-list a:hover h3::before {
		content: '▶ ';
		font-size: 0.75rem;
		color: var(--phosphor);
	}

	p {
		color: var(--silver-dim);
	}

	@media (max-width: 640px) {
		.post-list a {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
	}
</style>
